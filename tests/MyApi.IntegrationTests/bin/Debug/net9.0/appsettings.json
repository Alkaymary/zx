{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "MyApi",
    "Audience": "MyApiClient",
    "SecretKey": "",
    "ExpiryMinutes": 120
  },
  "Serilog": {
    "EnableFileLogging": false,
    "FilePath": "",
    "RetainedFileCountLimit": 14,
    "SeqServerUrl": "",
    "RequestLogging": {
      "SlowRequestThresholdMs": 2000
    },
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    }
  },
  "Cors": {
    "AllowedOrigins": [],
    "AllowLocalhostOriginsInDevelopment": true
  },
  "RateLimiting": {
    "Login": {
      "PermitLimit": 5,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Refresh": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "BootstrapAdmin": {
    "Enabled": false,
    "FullName": "",
    "Username": "",
    "Email": "",
    "PhoneNumber": "",
    "Password": "",
    "RoleCode": "super_admin"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
